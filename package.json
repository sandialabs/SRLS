{
    "name": "srls-sandiarpmlanesimulator",
    "private": true,
    "version": "1.2.0",
    "author": "Pete Humphrey, Alfred Johnson, Jonathan Marney",
    "main": "out/main/index.js",
    "type2": "module",
    "scripts": {
        "devx": "cross-env NODE_ENV=development electron .",
        "dev": "electron-vite dev",
        "vite": "electron-vite",
        "build": "vue-tsc -b && electron-vite build",
        "dist": "npm run build && electron-builder",
        "start": "npm run dev",
        "app:dev": "vue-tsc && concurrently electron-vite \" electron .\" \"vue-tsc -w\"",
        "app:build": "npm run build && tsc && electron-builder",
        "app:preview": "npm run build && tsc && electron .",
        "typecheck": "vue-tsc --noEmit"
    },
    "scripts2": {
        "vite:dev": "vite",
        "vite:build": "vue-tsc --noEmit && vite build",
        "vite:preview": "vite preview",
        "ts": "tsc",
        "watch": "tsc -w",
        "lint": "eslint -c .eslintrc --ext .ts ./src"
    },
    "build": {
        "appId": "YourAppID",
        "asar": true,
        "directories": {
            "buildResources": "assets",
            "output": "release/${version}"
        },
        "files": [
            "dist"
        ],
        "mac": {
            "artifactName": "${productName}_${version}.${ext}",
            "target": [
                "dmg"
            ]
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "artifactName": "${productName}_${version}.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "deleteAppDataOnUninstall": false
        }
    },
    "dependencies": {
        "@electron/remote": "^2.1.2",
        "chart.js": "^4.5.0",
        "express": "^5.2.1",
        "moment": "^2.30.1",
        "net": "^1.0.2",
        "vue": "^3.5.24",
        "vue-router": "^5.0.2",
        "vuetify": "^3.11.8"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "@mdi/font": "^7.4.47",
        "@types/express": "^5.0.6",
        "@types/node": "^24.10.1",
        "@vitejs/plugin-vue": "^6.0.1",
        "@vue/tsconfig": "^0.8.1",
        "concurrently": "^7.2.2",
        "cross-env": "^10.1.0",
        "electron": "^39.2.7",
        "electron-builder": "^24.13.3",
        "electron-vite": "^5.0.0",
        "pinia": "^3.0.4",
        "typescript": "~5.9.3",
        "vite": "^7.2.4",
        "vite-plugin-vuetify": "^2.1.3",
        "vue-tsc": "^3.1.4"
    }
}
