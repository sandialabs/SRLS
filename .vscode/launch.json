{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Electron: Dev (electron-vite + Main)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Electron: Renderer (attach)",
            "type": "pwa-chrome",
            "request": "attach",
            "port": 9222,
            "urlFilter": "http://localhost:*",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true
        },
        {
            "name": "Electron: Prod (built main)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
            "windows": {
                "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
            },
            "program": "${workspaceFolder}/out/main/index.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "sourceMaps": true,
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Electron: All (Dev)",
            "configurations": [
                "Electron: Dev (electron-vite + Main)",
                "Electron: Renderer (attach)"
            ],
            "stopAll": true
        }
    ]
}